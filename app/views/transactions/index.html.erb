<section class="content-card mb-4">
  <h2 class="section-title">Transactions</h2>
  <p class="section-subtitle mb-3">Search and sort your operations by date, amount, and category.</p>

  <%= form_with url: transactions_path, method: :get, local: true, class: "row g-2 align-items-end mb-0" do %>
    <div class="col-12 col-md-3">
      <%= label_tag :query, "Description", class: "form-label text-light small mb-1" %>
      <%= text_field_tag :query, params[:query], class: "form-control", placeholder: "Coffee, Grocery..." %>
    </div>
    <div class="col-12 col-md-2">
      <%= label_tag :mcc, "MCC", class: "form-label text-light small mb-1" %>
      <%= number_field_tag :mcc, params[:mcc], class: "form-control no-spinners", placeholder: "5411", inputmode: "numeric" %>
    </div>
    <div class="col-6 col-md-2">
      <%= label_tag :filter_from_date, "From", class: "form-label text-light small mb-1" %>
      <%= date_field_tag :filter_from_date, params[:filter_from_date].presence || @default_filter_from_date, class: "form-control" %>
    </div>
    <div class="col-6 col-md-2">
      <%= label_tag :filter_to_date, "To", class: "form-label text-light small mb-1" %>
      <%= date_field_tag :filter_to_date, params[:filter_to_date].presence || Date.current, class: "form-control" %>
    </div>
    <div class="col-12 col-md-3">
      <button class="btn btn-primary w-100" type="submit">Apply Filters</button>
    </div>
  <% end %>
</section>

<section class="content-card mb-4">
  <div class="table-responsive">
    <table class="table table-dark table-hover table-striped align-middle mb-0 app-table">
      <thead>
        <tr>
          <th scope="col">
            <%= link_to @time_sort_label,
                        transactions_path(@time_sort_params),
                        class: "table-link" %>
          </th>
          <th scope="col">Description</th>
          <th scope="col">MCC</th>
          <th scope="col">
            <%= link_to @amount_sort_label,
                        transactions_path(@amount_sort_params),
                        class: "table-link" %>
          </th>
        </tr>
      </thead>
      <tbody>
        <% @transactions.each do |transaction| %>
          <tr>
            <td><%= currency_date(transaction.time_int) %> </td>
            <td><%= transaction.description %></td>
            <td><%= "#{MCC.code(transaction.mcc)&.usda_description} #{transaction.mcc}" %></td>
            <td><%= Money.from_cents(transaction.amount, 'UAH').format %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<div class="mt-3">
  <%== pagy_bootstrap_nav(@pagy) %>
</div>

<div class="row text-center g-3">
  <div class="col-md-4">
    <div class="content-card ui-block stats-card h-100">
      <small class="text-light">Total transactions</small>
      <h5 class="my-1 text-info"><%= @pagy.count %></h5>
    </div>
  </div>

  <div class="col-md-4">
    <div class="content-card ui-block stats-card h-100">
      <small class="text-light">Total Spent</small>
      <h5 class="my-1 text-danger"><%= Money.from_cents(@total_spent, 'UAH').format %></h5>
    </div>
  </div>

  <div class="col-md-4">
    <div class="content-card ui-block stats-card h-100">
      <small class="text-light">Total Income</small>
      <h5 class="my-1 text-success"><%= Money.from_cents(@total_income, 'UAH').format %></h5>
    </div>
  </div>
</div>

<div class="mb-4">
  <%= form_with url: sync_transactions_path, method: :post, local: true, class: "content-card ui-block p-3 row g-2 align-items-end w-100 mt-3 mx-0" do %>
    <div class="col-12">
      <p class="section-subtitle mb-1">Fetch fresh transactions</p>
    </div>
    <div class="col-6 col-md-4">
      <%= label_tag :from_date, "From", class: "form-label text-light small mb-1" %>
      <%= date_field_tag :from_date, params[:from_date].presence || @default_sync_from_date, class: "form-control" %>
    </div>
    <div class="col-6 col-md-4">
      <%= label_tag :to_date, "To", class: "form-label text-light small mb-1" %>
      <%= date_field_tag :to_date, params[:to_date].presence || Date.current, class: "form-control" %>
    </div>
    <div class="col-12 col-md-4">
      <%= submit_tag "Sync Now", class: "btn btn-outline-light w-100" %>
    </div>
  <% end %>
</div>
